# golflessons.be — environment variables
# Copy to .env.local and fill in. Some are managed via Vercel marketplace
# integrations and auto-injected on deploy.

# ─── Core ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://golflessons.be
NEXT_PUBLIC_BASE_URL=https://golflessons.be
NEXT_PUBLIC_SITE_URL=https://golflessons.be
AUTH_SECRET=                       # 32+ char random string, JWT signing
CRON_SECRET=                       # protects /api/cron/* endpoints

# ─── Database (Neon, via Vercel marketplace) ───────────────
POSTGRES_URL=                      # pooled connection
POSTGRES_URL_NON_POOLING=          # direct connection (for migrations)
POSTGRES_URL_PREVIEW=              # preview branch DB
POSTGRES_URL_PREVIEW_NON_POOLING=
DB_POSTGRES_URL=                   # legacy alias used in some places

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=                 # sk_live_… or sk_test_…
STRIPE_WEBHOOK_SECRET=             # whsec_…
STRIPE_PRICE_ANNUAL=               # price_… for annual pro subscription
STRIPE_PRICE_MONTHLY=              # price_… for monthly pro subscription
NEXT_PUBLIC_PRO_PRICE_MONTHLY=12.5 # Display price in EUR for UI; defaults to 12.5
NEXT_PUBLIC_PRO_PRICE_ANNUAL=125   # Display price in EUR for UI; defaults to 125
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=2.5   # Platform commission on every priced booking; defaults to 2.5
NEXT_PUBLIC_STRIPE_SURCHARGE_PERCENT=2.5 # Extra % added when the student pays online (covers Stripe fees); defaults to 2.5
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Vercel Blob ────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=             # auto-injected on Vercel

# ─── Email (Gmail API via Google Workspace service account) ─
GMAIL_SEND_AS=noreply@golflessons.be
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ─── Google OAuth (sign in with Google) ─────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Sentry (error tracking) ────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ORG=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=                 # for sourcemap upload during build
SENTRY_READ_TOKEN=                 # for /dev/sentry browser
SENTRY_WEBHOOK_CLIENT_SECRET_PREVIEW=
SENTRY_WEBHOOK_CLIENT_SECRET_PRODUCTION=

# ─── Push notifications (Web Push, VAPID) ──────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@golflessons.be

# ─── ntfy (incident push to phones) ────────────────────────
NTFY_URL=
NTFY_TOPIC=
NTFY_AUTH=

# ─── Vercel Logs (for /dev/logs) ───────────────────────────
LOGS_VERCEL_TOKEN=                 # team token with logs:read
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# ─── reCAPTCHA v3 (public booking spam protection) ────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=    # client key (visible in HTML)
RECAPTCHA_SECRET_KEY=              # server secret for token verification
# Used by /book/[slug] booking action. If unset, verifier returns score 0
# and bookings still go through (graceful degrade — rate limit is primary).

# ─── Upstash Redis (rate limiter for public booking) ───────
KV_REST_API_URL=                   # auto-injected via Vercel marketplace
KV_REST_API_TOKEN=                 # auto-injected via Vercel marketplace
# Backs Ratelimit.slidingWindow(5, "1h") on /book/[slug]. If unreachable
# the rate limiter throws and bookings fail — required in production.

# ─── AI Gateway (only if /api/ai is connected to a model) ──
GATEWAY_URL=
GATEWAY_API_KEY=

# ─── WebSocket gateway (notifications) ─────────────────────
NEXT_PUBLIC_WS_GATEWAY_URL=

# ─── Build metadata (auto-set by Vercel) ───────────────────
# NEXT_PUBLIC_BUILD_ID=
# VERCEL_ENV=
# VERCEL_URL=
# VERCEL_GIT_COMMIT_SHA=
